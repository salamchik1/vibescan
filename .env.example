# ---- Scanner service (apps/scanner) ----
# Port the Fastify scanner listens on
SCANNER_PORT=8787
# Shared secret required in the X-Scan-Secret header (web -> scanner). Generate a long random string.
SCANNER_SHARED_SECRET=change-me-to-a-long-random-string
# Comma-separated origins allowed to call the scanner (your web app origin)
SCANNER_ALLOWED_ORIGINS=http://localhost:3000
# Per-IP rate limit: max scans per window
SCANNER_RATE_MAX=5
SCANNER_RATE_WINDOW_MS=60000
# Hard timeout per scan (ms)
SCANNER_TIMEOUT_MS=75000
# Optional: set to "1" to also run gitleaks if the binary is on PATH (Docker/CI). Local Windows can leave unset.
SCANNER_USE_GITLEAKS=0
# Secret liveness: make one read-only call per detected key (OpenAI, Anthropic, Stripe, GitHub,
# GitLab, SendGrid, Hugging Face, DigitalOcean, Telegram, Slack) to confirm it still works.
# On by default; set to "0" to disable all outbound verification calls.
SCANNER_VERIFY_SECRETS=1

# ---- "online" agent (tools/scanner-online.mjs) ----
# Public tunnel used to expose the local scanner to the Vercel site.
# cloudflared (default — free, no account, reliable) | tunnelmole | localtunnel.
# tunnelmole's free service is flaky (often never emits a URL), so cloudflared
# is the default. cloudflared: install from https://github.com/cloudflare/cloudflared/releases
TUNNEL_PROVIDER=cloudflared
# Optional: full path to cloudflared.exe if it is not on your PATH.
# CLOUDFLARED_PATH=C:\Program Files (x86)\cloudflared\cloudflared.exe

# ---- Web app (apps/web) ----
# Where the web server-route forwards scans (server-side only, never exposed to the browser)
SCANNER_URL=http://localhost:8787
# Must match SCANNER_SHARED_SECRET above (server-side only)
SCANNER_SHARED_SECRET=change-me-to-a-long-random-string
# Have I Been Pwned API key — enables the Data Breach Checker tool (/tools/breach).
# Get one at https://haveibeenpwned.com/API/Key. Leave unset to disable that tool.
HIBP_API_KEY=

# ---- Supabase (report persistence + magic-link accounts) ----
# Leave these blank to keep VibeScan working as a free one-shot scanner with no
# backend. Fill them in to save reports at /r/{id}, enable login, and show history.
# Find them in your Supabase project: Settings → API.
# Project URL (e.g. https://abcdefgh.supabase.co) — public, used in the browser.
NEXT_PUBLIC_SUPABASE_URL=
# anon/public key — public, used in the browser for auth.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key — SERVER ONLY, full DB access. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Optional: canonical site origin used to build magic-link redirects.
# Defaults to the request host (fine for localhost). Set in production, e.g.
# https://vibescan.app
NEXT_PUBLIC_SITE_URL=
